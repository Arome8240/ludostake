# ─── Celo RPC ────────────────────────────────────────────────────────────────
# Public mainnet RPC (no auth required for read-only)
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org

# Alfajores testnet (for local development)
NEXT_PUBLIC_CELO_TESTNET_RPC_URL=https://alfajores-forno.celo-testnet.org

# ─── WalletConnect ───────────────────────────────────────────────────────────
# Required for RainbowKit / wagmi on non-MiniPay browsers
# Get yours at https://cloud.walletconnect.com
NEXT_PUBLIC_WC_PROJECT_ID=your_walletconnect_project_id_here

# ─── Smart Contract ───────────────────────────────────────────────────────────
# LudoStakes.sol deployed address (Celo Alfajores testnet)
NEXT_PUBLIC_CONTRACT_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000

# LudoStakes.sol deployed address (Celo mainnet)
NEXT_PUBLIC_CONTRACT_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000

# Protocol treasury address (receives 8% fee)
NEXT_PUBLIC_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Colyseus Multiplayer Server ─────────────────────────────────────────────
NEXT_PUBLIC_COLYSEUS_URL=ws://localhost:2567

# ─── Feature Flags ───────────────────────────────────────────────────────────
# Set to "testnet" for local dev, "mainnet" for production
NEXT_PUBLIC_NETWORK=testnet
